# Terra Agent Configuration
# 复制此文件为 .env 并填写你的实际配置

# ── MiMo API (必填) ──
# 支持单 Key 或多 Key（逗号分隔），多 Key 可实现并发绕过和故障切换
MIMO_API_KEY=your-api-key-here
# 示例：MIMO_API_KEY=key1,key2,key3

# ── Android ADB (必填) ──
ADB_PATH=C:\platform-tools\adb.exe

# ── 模拟器配置 ──
# 类型: mumu, ldplayer, bluestacks, generic
EMULATOR_TYPE=mumu

# 模拟器控制台路径（MuMu 示例）
# EMULATOR_CONSOLE=C:\Program Files\MuMu\emulator\nemu\emulator\MuMuManager.exe

# 模拟器实例名称（索引或名称）
# EMULATOR_INSTANCE=0

# 内存上限 MB（超出自动重启）
# EMULATOR_MEMORY_LIMIT_MB=6144

# 定时重启 cron 表达式（默认每天凌晨 4 点）
# EMULATOR_RESTART_CRON=0 4 * * *

# ── 微信网关 ──
# 微信 Bot 登录 Token 加密密钥（可选，首次扫码后自动生成）
# TOKEN_ENCRYPTION_KEY=

# ── SSL/TLS（可选） ──
# GATEWAY_SSL_VERIFY=true
# GATEWAY_SSL_CERT_PATH=path/to/cert.pem

# ── MAA 工具（可选） ──
# MAA_ROOT=D:\MAA-v6.11.1-win-x64
